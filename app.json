{
  "expo": {
    "name": "LetsPlay",
    "slug": "letsplay",
    "scheme": "letsplay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "ca.letsplayapp.letsplay",
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "LetsPlay needs access to your photo library to set your profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "LetsPlay uses your location to sort nearby events."
        }
      ],
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": false
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7099be21-e3b5-4ef5-815e-6d0039f47150"
      }
    }
  }
}
